rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      // Check for hardcoded admin UID from login logic or the admin role in the user profile
      return request.auth != null && (
        request.auth.uid == 'MGJvxAVghfZZpaiz2ElhDq6dTXp1' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Usuarios: solo pueden leer/escribir su propio perfil, admin puede ver todos
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write, update: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Transacciones: solo el dueño puede ver las suyas, admin todas
    match /transactions/{docId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAdmin();
    }

    // Retiros: solo el dueño lee las suyas, admin gestiona todas
    match /withdrawals/{docId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAdmin();
    }

    // Anuncios: lectura para autenticados, admin gestiona
    match /ads/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Noticias: lectura pública para autenticados, admin gestiona
    match /news/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Configuraciones
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
