{
  "manifest_version": 3,
  "name": "FastAds - Herramienta Oficial",
  "version": "1.0.1",
  "description": "Extensión oficial de FastAds para la visualización segura de anuncios y sincronización de recompensas.",
  "icons": {
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ]
    }
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ]
}